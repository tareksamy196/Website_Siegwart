@model IEnumerable<Website.Siegwart.BLL.Dtos.Admin.VideoMedia.VideoMediaListItemDto>
@{
    ViewData["Title"] = "Video Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">
            <i class="bi bi-camera-video me-2"></i> Video Gallery
        </h2>
        <p class="text-muted mb-0">Manage your gallery videos (YouTube)</p>
    </div>

    <div class="d-flex gap-2">
        <div class="input-group" style="width: 300px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input id="tableSearch" type="text" class="form-control" placeholder="Search videos..." />
        </div>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Video
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="dataTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;">#</th>
                            <th style="width: 100px;">Thumbnail</th>
                            <th>Title</th>
                            <th style="width: 140px;">Created</th>
                            <th style="width: 110px;">Status</th>
                            <th class="text-center" style="width: 220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">@item.Id</td>
                                <td>
                                    <img src="@(string.IsNullOrWhiteSpace(item.ThumbnailUrl) ? $"https://img.youtube.com/vi/{item.VideoId}/hqdefault.jpg" : item.ThumbnailUrl)"
                                         alt="Thumb @item.VideoId"
                                         style="width:100px;height:58px;object-fit:cover;border-radius:8px;border:1px solid #e9ecef;" />
                                </td>
                                <td>
                                    <strong>@(string.IsNullOrWhiteSpace(item.TitleEn) ? "-" : item.TitleEn)</strong><br />
                                    <small class="text-muted" dir="rtl">@(!string.IsNullOrWhiteSpace(item.TitleAr) ? item.TitleAr : "")</small>
                                </td>
                                <td>
                                    <small>
                                        @item.CreatedOn.ToString("dd/MM/yyyy")<br />
                                        <span class="text-muted">@item.CreatedOn.ToString("HH:mm")</span>
                                    </small>
                                </td>
                                <td>
                                    @if (item.IsPublished)
                                    {
                                        <span class="badge bg-success">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Draft</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <!-- Delete: posts to /admin/video/delete/{id} -->
                                        <button type="button"
                                                class="btn btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@item.Id"
                                                data-name="@(item.TitleEn)"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>

                                        <!-- Toggle Publish: posts to /admin/video/togglepublish/{id} -->
                                        <form asp-action="TogglePublish" asp-route-id="@item.Id" method="post" class="d-inline-block ms-1">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="publish" value="@(item.IsPublished ? "false" : "true")" />
                                            <button type="submit" class="btn btn-outline-secondary" title="Toggle Publish">
                                                <i class="bi @(item.IsPublished ? "bi-eye-fill text-success" : "bi-eye-slash text-muted")"></i>
                                            </button>
                                        </form>

                                        <a class="btn btn-outline-info" target="_blank" rel="noopener"
                                           href="https://www.youtube.com/watch?v=@item.VideoId" title="Open on YouTube">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-camera-video display-1 text-muted"></i>
                <p class="mt-3 text-muted">
                    No videos yet. <a asp-action="Create" class="fw-bold">Add your first video</a>
                </p>
            </div>
        }
    </div>
</div>
<partial name="_DeleteModalPartial" />
@section Scripts {
    <script>
        document.getElementById('tableSearch')?.addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#dataTable tbody tr').forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(q) ? '' : 'none';
            });
        });
    </script>
}