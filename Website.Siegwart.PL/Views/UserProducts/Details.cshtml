@model Website.Siegwart.BLL.Dtos.User.UserProductDto
@using Website.Siegwart.PL.Helper

@{
    ViewData["Title"] = LocalizedText.Pick(Context, Model.TitleEn, Model.TitleAr);
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAr = LocalizedText.IsArabic(Context);
    var currentUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
    var titleText = LocalizedText.Pick(Context, Model.TitleEn, Model.TitleAr);
    var catText = LocalizedText.Pick(Context, Model.CategoryNameEn, Model.CategoryNameAr);
    var descText = LocalizedText.Pick(Context, Model.DescriptionEn, Model.DescriptionAr);
}

<!-- ══════════════════════════════ BREADCRUMB -->
<nav class="pd-breadcrumb" aria-label="breadcrumb">
    <div class="container">
        <ol class="pd-breadcrumb__list @(isAr ? "rtl" : "")">
            <li>
                <a asp-controller="Home" asp-action="Index">
                    @LocalizedText.Pick(Context, "Home", "الرئيسية")
                </a>
            </li>
            <li class="pd-breadcrumb__sep" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
                    <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.6"
                          stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </li>
            <li>
                <a asp-controller="Products" asp-action="Index">
                    @LocalizedText.Pick(Context, "Products", "المنتجات")
                </a>
            </li>
            <li class="pd-breadcrumb__sep" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
                    <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.6"
                          stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </li>
            <li class="pd-breadcrumb__active" aria-current="page">@titleText</li>
        </ol>
    </div>
</nav>

<!-- ══════════════════════════════ MAIN LAYOUT -->
<section class="pd-section">
    <div class="container">

        <!-- TOP BLOCK: image + info side by side -->
        <div class="pd-top pd--reveal">

            <!-- ── LEFT: Image Panel ──────────────────── -->
            <div class="pd-image-panel">
                <div class="pd-image-panel__inner">
                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <figure class="pd-figure" id="zoomTarget">
                            <img src="@Url.Content("~/" + Model.ImageUrl)"
                                 alt="@titleText"
                                 class="pd-figure__img"
                                 id="mainProductImage" />
                        </figure>
                        <button class="pd-zoom-btn" id="zoomBtn" aria-label="Zoom image">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8" />
                                <path d="M16.5 16.5L21 21M11 8v6M8 11h6" stroke="currentColor"
                                      stroke-width="1.8" stroke-linecap="round" />
                            </svg>
                            @LocalizedText.Pick(Context, "Zoom", "تكبير")
                        </button>
                    }
                    else
                    {
                        <div class="pd-no-image">
                            <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                                <rect x="6" y="14" width="52" height="40" rx="4"
                                      stroke="currentColor" stroke-width="2" />
                                <circle cx="22" cy="28" r="5" stroke="currentColor" stroke-width="2" />
                                <path d="M6 42l14-12 10 10 8-8 12 12" stroke="currentColor"
                                      stroke-width="2" stroke-linejoin="round" />
                            </svg>
                            <p>@LocalizedText.Pick(Context, "No image available", "لا توجد صورة")</p>
                        </div>
                    }

                    <!-- Utility pill row -->
                    <div class="pd-util-row">
                        <button class="pd-util-btn" id="printBtn">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                                <path d="M6 9V4h12v5M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v6H6v-6z"
                                      stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                            </svg>
                            @LocalizedText.Pick(Context, "Print", "طباعة")
                        </button>
                        <button class="pd-util-btn" id="shareBtn">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                                <circle cx="18" cy="5" r="3" stroke="currentColor" stroke-width="1.8" />
                                <circle cx="6" cy="12" r="3" stroke="currentColor" stroke-width="1.8" />
                                <circle cx="18" cy="19" r="3" stroke="currentColor" stroke-width="1.8" />
                                <path d="M8.59 13.51l6.83 3.98M15.41 6.51L8.59 10.49"
                                      stroke="currentColor" stroke-width="1.8" />
                            </svg>
                            @LocalizedText.Pick(Context, "Share", "مشاركة")
                        </button>
                    </div>
                </div>
            </div>

            <!-- ── RIGHT: Info Panel ──────────────────── -->
            <div class="pd-info-panel @(isAr ? "rtl" : "")">

                <!-- Category chip -->
                <div class="pd-chip">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M1 1h6l7 7-6 6-7-7V1z" />
                    </svg>
                    @catText
                </div>

                <!-- Title -->
                <h1 class="pd-title">@titleText</h1>
                <div class="pd-rule"></div>

                <!-- Inline meta row -->
                <div class="pd-meta-row">
                    <div class="pd-meta-item">
                        <span class="pd-meta-label">@LocalizedText.Pick(Context, "Code", "الكود")</span>
                        <span class="pd-meta-value">SIEG-@Model.Id.ToString("D6")</span>
                    </div>
                    <div class="pd-meta-div"></div>
                    <div class="pd-meta-item">
                        <span class="pd-meta-label">@LocalizedText.Pick(Context, "Status", "الحالة")</span>
                        <span class="pd-meta-value pd-meta-value--green">
                            <span class="pd-dot"></span>
                            @LocalizedText.Pick(Context, "In Stock", "متوفر")
                        </span>
                    </div>
                    <div class="pd-meta-div"></div>
                    <div class="pd-meta-item">
                        <span class="pd-meta-label">@LocalizedText.Pick(Context, "Standards", "المعايير")</span>
                        <span class="pd-meta-value">ISO 9001</span>
                    </div>
                </div>

                <!-- Description -->
                <p class="pd-desc">@descText</p>

                <!-- Features grid -->
                <div class="pd-features">
                    <div class="pd-feature">
                        <div class="pd-feature__icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path d="M12 2l3 6.5L22 10l-5 4.5L18 22l-6-3.5L6 22l1-7.5L2 10l7-1.5L12 2z"
                                      stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                            </svg>
                        </div>
                        <div>
                            <strong>@LocalizedText.Pick(Context, "Premium Quality", "جودة عالية")</strong>
                            <p>@LocalizedText.Pick(Context, "Manufactured using premium materials", "مواد فائقة الجودة")</p>
                        </div>
                    </div>
                    <div class="pd-feature">
                        <div class="pd-feature__icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path d="M9 12l2 2 4-4M12 3C6.477 3 2 7.477 2 13s4.477 10 10 10 10-4.477 10-10S17.523 3 12 3z"
                                      stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                            </svg>
                        </div>
                        <div>
                            <strong>@LocalizedText.Pick(Context, "Int'l Standards", "معايير دولية")</strong>
                            <p>@LocalizedText.Pick(Context, "Complies with international standards", "يتوافق مع المعايير الدولية")</p>
                        </div>
                    </div>
                    <div class="pd-feature">
                        <div class="pd-feature__icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"
                                      stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                            </svg>
                        </div>
                        <div>
                            <strong>@LocalizedText.Pick(Context, "Durable Build", "متانة عالية")</strong>
                            <p>@LocalizedText.Pick(Context, "Built to last with exceptional reliability", "مصمم للمتانة والموثوقية")</p>
                        </div>
                    </div>
                    <div class="pd-feature">
                        <div class="pd-feature__icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                                      fill="currentColor" />
                            </svg>
                        </div>
                        <div>
                            <strong>@LocalizedText.Pick(Context, "Made in Egypt", "صنع في مصر")</strong>
                            <p>@LocalizedText.Pick(Context, "Proudly manufactured locally", "مصنوع بفخر في مصر")</p>
                        </div>
                    </div>
                </div>

                <!-- CTA -->
                <div class="pd-cta-row">
                    <a asp-controller="Home" asp-action="Contact" class="pd-btn pd-btn--primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                                  stroke="currentColor" stroke-width="1.8" />
                            <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.8" />
                        </svg>
                        @LocalizedText.Pick(Context, "Request a Quote", "طلب عرض سعر")
                    </a>
                    <a asp-action="Index" class="pd-btn pd-btn--ghost">
                        @if (!isAr)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                <path d="M20 12H4M4 12l8-8M4 12l8 8" stroke="currentColor"
                                      stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        }
                        @LocalizedText.Pick(Context, "All Products", "كل المنتجات")
                        @if (isAr)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                <path d="M4 12h16M16 6l6 6-6 6" stroke="currentColor"
                                      stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        }
                    </a>
                </div>

                <!-- Contact strip -->
                <div class="pd-contact-strip">
                    <a href="tel:+201234567890" class="pd-contact-item">
                        <div class="pd-contact-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                                <path d="M22 16.92v3a2 2 0 01-2.18 2A19.79 19.79 0 013.09 4.18 2 2 0 015.08 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L9.09 9.91a16 16 0 006.99 7l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
                                      stroke="currentColor" stroke-width="1.8" />
                            </svg>
                        </div>
                        <div>
                            <small>@LocalizedText.Pick(Context, "Call us", "اتصل بنا")</small>
                            <strong>
                                ⁦+20 10 35895684⁩
                            </strong>
                        </div>
                    </a>
                    <div class="pd-contact-div"></div>
                    <a href="mailto:info@@siegwart.com" class="pd-contact-item">
                        <div class="pd-contact-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                                      stroke="currentColor" stroke-width="1.8" />
                                <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.8" />
                            </svg>
                        </div>
                        <div>
                            <small>@LocalizedText.Pick(Context, "Email us", "راسلنا")</small>
                            <strong>info@@siegwart.com</strong>
                        </div>
                    </a>
                </div>

            </div>
        </div>

    </div>
</section>

<!-- ══════════════════════════════ SHARE MODAL -->
<div class="modal fade" id="shareModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content pd-modal">
            <div class="pd-modal__header">
                <h5>@LocalizedText.Pick(Context, "Share this product", "مشاركة المنتج")</h5>
                <button type="button" class="pd-modal__close" data-bs-dismiss="modal" aria-label="Close">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2"
                              stroke-linecap="round" />
                    </svg>
                </button>
            </div>
            <div class="pd-modal__body">
                <div class="pd-share-grid">
                    <a href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(currentUrl)"
                       target="_blank" rel="noopener" class="pd-share-pill pd-share-pill--fb">
                        <i class="bi bi-facebook"></i> Facebook
                    </a>
                    <a href="https://twitter.com/intent/tweet?url=@Uri.EscapeDataString(currentUrl)&text=@Uri.EscapeDataString(titleText)"
                       target="_blank" rel="noopener" class="pd-share-pill pd-share-pill--tw">
                        <i class="bi bi-twitter-x"></i> Twitter
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=@Uri.EscapeDataString(currentUrl)"
                       target="_blank" rel="noopener" class="pd-share-pill pd-share-pill--li">
                        <i class="bi bi-linkedin"></i> LinkedIn
                    </a>
                    <a href="https://wa.me/?text=@Uri.EscapeDataString(titleText + " " + currentUrl)"
                       target="_blank" rel="noopener" class="pd-share-pill pd-share-pill--wa">
                        <i class="bi bi-whatsapp"></i> WhatsApp
                    </a>
                </div>
                <div class="pd-copy-row">
                    <input type="text" class="pd-copy-input" id="shareLink" value="@currentUrl" readonly>
                    <button class="pd-copy-btn" id="copyLinkBtn">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <rect x="9" y="9" width="13" height="13" rx="2"
                                  stroke="currentColor" stroke-width="1.8" />
                            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                                  stroke="currentColor" stroke-width="1.8" />
                        </svg>
                        @LocalizedText.Pick(Context, "Copy", "نسخ")
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════ LIGHTBOX -->
<div class="pd-lightbox" id="imageLightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="pd-lightbox__close" id="closeLightbox" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
    </button>
    <img id="lightboxImage" src="" alt="" class="pd-lightbox__img">
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Product.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Product-Details.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/product-details.js" asp-append-version="true"></script>
}
