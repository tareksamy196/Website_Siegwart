@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    var pageTitle = (ViewData["Title"] as string) ?? "Admin Panel";
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();

    bool isDashboard = controller == "admindashboard";
    bool isCategories = controller == "admincategories";
    bool isProducts = controller == "adminproducts";
    bool isNews = controller == "adminnews";
    bool isTeam = controller == "adminteammember";
    bool isVideoGallery = controller == "adminvideogallery";
    bool isAdmins = controller == "superadmin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />

    <title>@pageTitle - Siegwart Admin</title>


    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="57x57" href="~/Resources/favicons/apple-touch-icon-57.png">
    <link rel="apple-touch-icon" sizes="60x60" href="~/Resources/favicons/apple-touch-icon-60.png">
    <link rel="apple-touch-icon" sizes="72x72" href="~/Resources/favicons/apple-touch-icon-72.png">
    <link rel="apple-touch-icon" sizes="76x76" href="~/Resources/favicons/apple-touch-icon-76.png">
    <link rel="apple-touch-icon" sizes="114x114" href="~/Resources/favicons/apple-touch-icon-114.png">
    <link rel="apple-touch-icon" sizes="120x120" href="~/Resources/favicons/apple-touch-icon-120.png">
    <link rel="apple-touch-icon" sizes="144x144" href="~/Resources/favicons/apple-touch-icon-144.png">
    <link rel="apple-touch-icon" sizes="152x152" href="~/Resources/favicons/apple-touch-icon-152.png">
    <link rel="apple-touch-icon" sizes="167x167" href="~/Resources/favicons/apple-touch-icon-167.png">
    <link rel="apple-touch-icon" sizes="180x180" href="~/Resources/favicons/apple-touch-icon-180.png">
    <link rel="apple-touch-icon" sizes="1024x1024" href="~/Resources/favicons/apple-touch-icon-1024.png">
    <link rel="icon" type="image/png" sizes="16x16" href="~/Resources/favicons/favicon-16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="~/Resources/favicons/favicon-32.png">
    <link rel="icon" type="image/png" sizes="48x48" href="~/Resources/favicons/favicon-48.png">
    <link rel="icon" type="image/png" sizes="64x64" href="~/Resources/favicons/favicon-64.png">
    <link rel="icon" type="image/png" sizes="128x128" href="~/Resources/favicons/favicon-128.png">
    <link rel="icon" type="image/png" sizes="256x256" href="~/Resources/favicons/favicon-256.png">
    <link rel="manifest" href="~/Resources/favicons/site.webmanifest">

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
          crossorigin="anonymous" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/css/admin.bundle.min.css"
          asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="admin-body">
    <div class="d-flex">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-badge">S</div>
                <div class="brand-title">
                    <strong>Siegwart</strong>
                    <span>Admin Panel</span>
                </div>
            </div>

            <nav class="nav">
                <a asp-controller="AdminDashboard" asp-action="Index" class="@(isDashboard ? "active" : "")">
                    <span class="icon"><i class="bi bi-speedometer2"></i></span>
                    <span>Dashboard</span>
                </a>
                <a asp-controller="AdminCategories" asp-action="Index" class="@(isCategories ? "active" : "")">
                    <span class="icon"><i class="bi bi-tags"></i></span>
                    <span>Categories</span>
                </a>
                <a asp-controller="AdminProducts" asp-action="Index" class="@(isProducts ? "active" : "")">
                    <span class="icon"><i class="bi bi-box-seam"></i></span>
                    <span>Products</span>
                </a>
                <a asp-controller="AdminNews" asp-action="Index" class="@(isNews ? "active" : "")">
                    <span class="icon"><i class="bi bi-newspaper"></i></span>
                    <span>News</span>
                </a>
                <a asp-controller="AdminTeamMember" asp-action="Index" class="@(isTeam ? "active" : "")">
                    <span class="icon"><i class="bi bi-people"></i></span>
                    <span>Team Members</span>
                </a>

                <!-- Admins link (visible only to SuperAdmin) -->
                @if (User.IsInRole("SuperAdmin"))
                {
                    <a asp-controller="SuperAdmin" asp-action="Index" class="@(isAdmins ? "active" : "")">
                        <span class="icon"><i class="bi bi-shield-lock-fill"></i></span>
                        <span>Admins</span>
                    </a>
                }

                <a asp-controller="AdminVideoMedia" asp-action="Index" class="@(isVideoGallery ? "active" : "")">
                    <span class="icon"><i class="bi bi-camera-video"></i></span>
                    <span>Video Gallery</span>
                </a>
            </nav>
        </aside>

        <!-- Main -->
        <main class="main flex-grow-1">
            <div class="topbar d-flex justify-content-between align-items-center">
                <div>
                    <p class="subtitle mb-0">Admin Panel</p>
                    <h1 class="title">@pageTitle</h1>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <!-- Mobile menu toggle -->
                    <button class="btn btn-outline-secondary btn-sm d-lg-none"
                            type="button"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#adminMobileMenu"
                            aria-label="Toggle menu">
                        <i class="bi bi-list"></i>
                    </button>

                    <!-- View website -->
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-secondary btn-sm btn-icon d-none d-md-inline-flex"
                       target="_blank"
                       title="View Website">
                        <i class="bi bi-globe"></i>
                        <span class="d-none d-lg-inline">View Website</span>
                    </a>
                    <!-- User dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm btn-icon dropdown-toggle"
                                type="button"
                                id="userDropdown"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            <i class="bi bi-person-circle"></i>
                            <span class="d-none d-lg-inline">@User.Identity?.Name</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li>
                                <span class="dropdown-item-text">
                                    <strong>@User.Identity?.Name</strong><br />
                                    <small class="text-muted">Administrator</small>
                                </span>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form method="post" asp-controller="Account" asp-action="SignOut" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Alert Partial -->
            <partial name="_AlertPartial" />

            <!-- Content -->
            <div class="content">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Mobile offcanvas menu -->
    <div class="offcanvas offcanvas-start admin-offcanvas"
         tabindex="-1"
         id="adminMobileMenu"
         aria-labelledby="adminMobileMenuLabel">
        <div class="offcanvas-header">
            <div class="d-flex align-items-center gap-2">
                <div class="brand-badge">S</div>
                <h5 class="offcanvas-title mb-0" id="adminMobileMenuLabel">
                    <strong>Siegwart Admin</strong>
                </h5>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>

        <div class="offcanvas-body p-0">
            <div class="p-3 border-bottom">
                <div class="d-flex align-items-center gap-2">
                    <div class="bg-primary bg-opacity-10 rounded-circle p-2">
                        <i class="bi bi-person-fill text-primary"></i>
                    </div>
                    <div>
                        <div class="fw-bold small">@User.Identity?.Name</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Administrator</div>
                    </div>
                </div>
            </div>

            <nav class="nav flex-column p-2">
                @* Add Admin in mobile menu for SuperAdmin only *@
                @if (User.IsInRole("SuperAdmin"))
                {
                    <a asp-controller="SuperAdmin" asp-action="Index"
                       class="nav-link d-flex align-items-center"
                       data-bs-dismiss="offcanvas">
                        <i class="bi bi-shield-lock-fill me-2"></i>
                        <span>Admins</span>
                    </a>
                }

                <a asp-controller="AdminDashboard" asp-action="Index"
                   class="@(isDashboard ? "active" : "")" data-bs-dismiss="offcanvas">
                    <span class="icon"><i class="bi bi-speedometer2"></i></span>
                    <span>Dashboard</span>
                </a>
                <a asp-controller="AdminCategories" asp-action="Index"
                   class="@(isCategories ? "active" : "")" data-bs-dismiss="offcanvas">
                    <span class="icon"><i class="bi bi-tags"></i></span>
                    <span>Categories</span>
                </a>
                <a asp-controller="AdminProducts" asp-action="Index"
                   class="@(isProducts ? "active" : "")" data-bs-dismiss="offcanvas">
                    <span class="icon"><i class="bi bi-box-seam"></i></span>
                    <span>Products</span>
                </a>
                <a asp-controller="AdminNews" asp-action="Index"
                   class="@(isNews ? "active" : "")" data-bs-dismiss="offcanvas">
                    <span class="icon"><i class="bi bi-newspaper"></i></span>
                    <span>News</span>
                </a>
                <a asp-controller="AdminTeamMember" asp-action="Index"
                   class="@(isTeam ? "active" : "")" data-bs-dismiss="offcanvas">
                    <span class="icon"><i class="bi bi-people"></i></span>
                    <span>Team Members</span>
                </a>
                <a asp-controller="AdminVideoMedia" asp-action="Index"
                   class="@(isVideoGallery ? "active" : "")" data-bs-dismiss="offcanvas">
                    <span class="icon"><i class="bi bi-camera-video"></i></span>
                    <span>Video Gallery</span>
                </a>
            </nav>

            <div class="p-3 border-top mt-auto">
                <form method="post" asp-controller="Account" asp-action="SignOut" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 btn-icon">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz"
            crossorigin="anonymous"></script>

    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>