@using Website.Siegwart.PL.Helper
@inject IStaticTextService T

@{
    ViewData["Title"] = T.About("title");
    ViewData["Description"] = T.About("meta_description");
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAr = LocalizedText.IsArabic(Context);
}

<div class="about-page @(isAr ? "is-ar" : "is-en")">

    <!-- ═══════════════════════════════════════════════════════════════
         HERO SECTION
         ═══════════════════════════════════════════════════════════ -->
    <section class="about-hero">
        <div class="about-hero-overlay"></div>
        <div class="container">
            <div class="about-hero-content" data-aos="fade-up">
                <span class="about-hero-tag">@T.About("hero.tag")</span>
                <h1 class="about-hero-title">@T.About("hero.title")</h1>
                <p class="about-hero-lead">@T.About("hero.lead")</p>
                <div class="about-hero-badges">
                    @for (int i = 0; i < 3; i++)
                    {
                        <span class="about-badge" data-aos="fade-up" data-aos-delay="@((i + 1) * 100)">
                            <i class="bi bi-check-circle" aria-hidden="true"></i>
                            @T.About($"hero.badges.{i}")
                        </span>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         WHO WE ARE
         ═══════════════════════════════════════════════════════════ -->
    <section class="about-section">
        <div class="container">
            <div class="about-grid">
                <div class="about-content" data-aos="fade-right">
                    <h2 class="about-h2">@T.About("who_we_are.title")</h2>
                    <p class="about-p">@T.About("who_we_are.p1")</p>
                    <p class="about-p">@T.About("who_we_are.p2")</p>
                </div>
                <div class="about-stats" data-aos="fade-left">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="about-stat-card">
                            <div class="about-stat-icon">
                                @switch (i)
                                {
                                    case 0:
                                        <i class="fas fa-calendar-alt" aria-hidden="true"></i>
                                        break;
                                    case 1:
                                        <i class="fas fa-users" aria-hidden="true"></i>
                                        break;
                                    default:
                                        <i class="fas fa-industry" aria-hidden="true"></i>
                                        break;
                                }
                            </div>
                            <div class="about-stat-number" data-count="@T.About($"who_we_are.stats.{i}.n")">0</div>
                            <div class="about-stat-label">@T.About($"who_we_are.stats.{i}.t")</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         VISION & MISSION
         ═══════════════════════════════════════════════════════════ -->
    <section class="about-section about-section--alt">
        <div class="container">
            <div class="about-vision-grid">
                <div class="about-vision-card" data-aos="fade-up">
                    <div class="about-vision-icon">
                        <i class="fas fa-eye" aria-hidden="true"></i>
                    </div>
                    <h3 class="about-h3">@T.About("vision.title")</h3>
                    <p class="about-p">@T.About("vision.text")</p>
                </div>
                <div class="about-vision-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="about-vision-icon">
                        <i class="fas fa-bullseye" aria-hidden="true"></i>
                    </div>
                    <h3 class="about-h3">@T.About("mission.title")</h3>
                    <p class="about-p">@T.About("mission.text")</p>
                </div>
                <div class="about-vision-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="about-vision-icon">
                        <i class="fas fa-heart" aria-hidden="true"></i>
                    </div>
                    <h3 class="about-h3">@T.About("values.title")</h3>
                    <p class="about-p">@T.About("values.text")</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         TIMELINE
         ═══════════════════════════════════════════════════════════ -->
    <section class="about-section">
        <div class="container">
            <div class="about-section-header" data-aos="fade-up">
                <h2 class="about-h2">@T.About("timeline.title")</h2>
                <p class="about-p">@T.About("timeline.lead")</p>
            </div>
            <div class="about-timeline">
                @for (int i = 0; i < 5; i++)
                {
                    <div class="about-timeline-item" data-aos="fade-up" data-aos-delay="@(i * 100)">
                        <div class="about-timeline-year">
                            <i class="bi bi-calendar-event" aria-hidden="true"></i>
                            @T.About($"timeline.items.{i}.year")
                        </div>
                        <div class="about-timeline-content">
                            <h4 class="about-h4">@T.About($"timeline.items.{i}.title")</h4>
                            <p class="about-p">@T.About($"timeline.items.{i}.text")</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         CERTIFICATIONS
         ═══════════════════════════════════════════════════════════ -->
    <section class="about-section about-section--alt">
        <div class="container">
            <div class="about-section-header" data-aos="fade-up">
                <h2 class="about-h2">@T.About("cert.title")</h2>
                <p class="about-p">@T.About("cert.lead")</p>
            </div>
            <div class="about-cert-grid">
                @for (int i = 0; i < 3; i++)
                {
                    var certImage = i == 0 ? "cert-iso9001.jpg" : i == 1 ? "cert-iso14001.png" : "cert-iso45001.png";
                    <div class="about-cert-card" data-aos="fade-up" data-aos-delay="@(i * 100)">
                        <div class="about-cert-image">
                            <img src="/Resources/images/@certImage"
                                 alt="@T.About($"cert.list.{i}")"
                                 loading="lazy"
                                 width="400"
                                 height="300" />
                            <div class="about-cert-overlay">
                                <i class="bi bi-zoom-in"></i>
                            </div>
                        </div>
                        <div class="about-cert-content">
                            <h4 class="about-h4">@T.About($"cert.list.{i}")</h4>
                            <p class="about-cert-desc">@T.About($"cert.desc.{i}")</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         CTA SECTION
         ═══════════════════════════════════════════════════════════ -->
    <section class="about-cta">
        <div class="container">
            <div class="about-cta-content" data-aos="fade-up">
                <h2 class="about-h2 about-h2--light">@T.About("cta.title")</h2>
                <p class="about-p about-p--light">@T.About("cta.lead")</p>
                <div class="about-cta-actions">
                    <a asp-controller="Home" asp-action="Contact"
                       class="about-btn about-btn-primary"
                       aria-label="@T.About("cta.actions.contact")">
                        <span>@T.About("cta.actions.contact")</span>
                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </a>
                    <a asp-controller="UserProducts" asp-action="Index"
                       class="about-btn about-btn-outline"
                       aria-label="@T.About("cta.actions.products")">
                        <span>@T.About("cta.actions.products")</span>
                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

</div>

<!-- ═══════════════════════════════════════════════════════════════
     LIGHTBOX
     ═══════════════════════════════════════════════════════════ -->
<div class="about-lightbox" id="aboutLightbox" role="dialog" aria-modal="true" aria-label="@T.About("cert_lightbox_label")">
    <button type="button" class="about-lightbox-close" aria-label="@T.About("close")">
        <i class="bi bi-x-lg"></i>
    </button>
    <img id="aboutLightboxImage" src="" alt="Certificate" />
</div>

@section Styles {
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/About.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="~/js/about.js" asp-append-version="true" defer></script>
}
