@model Website.Siegwart.BLL.Dtos.Admin.SuperAdminAccount.AdminChangePasswordDto

@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var userName = ViewBag.UserName as string;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h4 class="mb-0">@ViewData["Title"]</h4>
                            @if (!string.IsNullOrEmpty(userName))
                            {
                                <small class="text-muted">User: @userName</small>
                            }
                        </div>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>

                    <form asp-action="ChangePassword" asp-route-id="@Model.UserId" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <input asp-for="UserId" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">New password</label>
                            <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="NewPassword" class="text-danger small d-block"></span>
                            <small class="form-text text-muted">At least 8 characters including upper/lower/number/symbol.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm new password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-key me-1"></i> Reset Password
                            </button>
                        </div>
                    </form>

                    <div class="mt-3">
                        <small class="text-muted">This operation will set the user's password immediately. The user will be able to log in with the new password.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}