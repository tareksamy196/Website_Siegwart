@model Website.Siegwart.BLL.Dtos.Account.ResetPasswordDto

@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Siegwart</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <style>
        body {
            background: linear-gradient(180deg,#f7f9fc,#eef4fb);
            min-height: 100vh;
        }

        .reset-card {
            max-width: 520px;
            margin: 40px auto;
            border-radius: .6rem;
            overflow: hidden;
        }

        .brand-bar {
            background: linear-gradient(90deg,#0d6efd,#6610f2);
            color: #fff;
            padding: 1.25rem 1.5rem;
        }

        .strength-bar {
            height: 8px;
            border-radius: 6px;
            background: #e9ecef;
            overflow: hidden;
        }

            .strength-bar > i {
                display: block;
                height: 100%;
                width: 0%;
                transition: width .2s;
            }

        .strength-weak {
            background: #dc3545
        }

        .strength-fair {
            background: #fd7e14
        }

        .strength-good {
            background: #ffc107
        }

        .strength-strong {
            background: #198754
        }

        .req-ok {
            color: #198754;
        }
    </style>
</head>
<body>
    <main class="container">
        <div class="card reset-card shadow-sm">
            <div class="brand-bar d-flex align-items-center">
                <img src="~/Resources/images/logo-white.png" alt="Siegwart" style="height:36px;margin-right:.75rem" onerror="this.style.display='none'" />
                <div>
                    <h5 class="mb-0">Siegwart</h5>
                    <small class="d-block opacity-75">Reset your account password</small>
                </div>
            </div>

            <div class="card-body p-4">
                <h4 class="mb-2">Set a new password</h4>
                <p class="text-muted mb-3">Choose a strong password. You will use it to sign in to the admin area.</p>

                @if (ViewData.ModelState?.ErrorCount > 0)
                {
                    <div class="alert alert-danger" role="alert">
                        <ul class="mb-0">
                            @foreach (var kv in ViewData.ModelState)
                            {
                                foreach (var err in kv.Value.Errors)
                                {
                                    <li>@err.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form asp-action="ResetPassword" method="post" novalidate id="resetForm" class="needs-validation">
                    @Html.AntiForgeryToken()
                    <input asp-for="Email" type="hidden" />
                    <input asp-for="Token" type="hidden" />

                    <div class="mb-3">
                        <label for="NewPassword" class="form-label">New password</label>
                        <div class="input-group">
                            <input asp-for="NewPassword" id="NewPassword" type="password" class="form-control" autocomplete="new-password" required minlength="8" />
                            <button type="button" class="btn btn-outline-secondary" data-toggle="toggle-new" aria-label="Toggle password visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label for="ConfirmPassword" class="form-label">Confirm password</label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" id="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" required />
                            <button type="button" class="btn btn-outline-secondary" data-toggle="toggle-confirm" aria-label="Toggle password visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label d-block">Password strength</label>
                        <div class="strength-bar mb-2" aria-hidden="true"><i id="strengthIndicator" class="strength-weak" style="width:0%"></i></div>
                        <div class="d-flex justify-content-between">
                            <small id="strengthText" class="text-muted">Enter a password to see strength</small>
                            <small id="strengthScore" class="text-muted"></small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <ul class="list-unstyled mb-0 small text-muted">
                            <li id="req-length">● At least 8 characters</li>
                            <li id="req-upper">● Uppercase letter</li>
                            <li id="req-lower">● Lowercase letter</li>
                            <li id="req-digit">● Number</li>
                            <li id="req-symbol">● Symbol</li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Login" asp-controller="Account" class="btn btn-outline-secondary">Back to login</a>
                        <button id="resetSubmit" type="submit" class="btn btn-primary">Set password</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Minimal JS: toggle visibility, score, and pre-submit checks
        (function () {
            const $ = (sel) => document.querySelector(sel);
            const newPass = $('#NewPassword'), conf = $('#ConfirmPassword'),
                  ind = $('#strengthIndicator'), txt = $('#strengthText'), scoreLbl = $('#strengthScore');
            const req = {
                len: $('#req-length'), up: $('#req-upper'), low: $('#req-lower'),
                digit: $('#req-digit'), sym: $('#req-symbol')
            };

            // simple score 0..5
            function score(p) {
                if (!p) return 0;
                let s = 0;
                if (p.length >= 8) s++;
                if (/[A-Z]/.test(p)) s++;
                if (/[a-z]/.test(p)) s++;
                if (/[0-9]/.test(p)) s++;
                if (/[^A-Za-z0-9]/.test(p)) s++;
                return s;
            }

            function update() {
                const p = newPass.value || '';
                const s = score(p);
                // update requirements
                req.len.classList.toggle('req-ok', p.length >= 8);
                req.up.classList.toggle('req-ok', /[A-Z]/.test(p));
                req.low.classList.toggle('req-ok', /[a-z]/.test(p));
                req.digit.classList.toggle('req-ok', /[0-9]/.test(p));
                req.sym.classList.toggle('req-ok', /[^A-Za-z0-9]/.test(p));
                // update bar
                const pct = Math.round((s / 5) * 100);
                ind.style.width = pct + '%';
                ind.className = s >= 4 ? 'strength-strong' : s === 3 ? 'strength-good' : s === 2 ? 'strength-fair' : 'strength-weak';
                txt.textContent = p ? (s >= 4 ? 'Very secure' : s === 3 ? 'Good' : s === 2 ? 'Fair' : 'Weak') : 'Enter a password to see strength';
                scoreLbl.textContent = p ? (s + '/5') : '';
            }

            // toggle visibility (single delegated handler)
            document.addEventListener('click', function (e) {
                const btn = e.target.closest('[data-toggle="toggle-new"], [data-toggle="toggle-confirm"]');
                if (!btn) return;
                const isNew = btn.getAttribute('data-toggle') === 'toggle-new';
                const input = isNew ? newPass : conf;
                const icon = btn.querySelector('i');
                if (!input) return;
                input.type = input.type === 'password' ? 'text' : 'password';
                if (icon) icon.classList.toggle('bi-eye-slash');
            });

            newPass && newPass.addEventListener('input', update);

            // submit checks
            document.getElementById('resetForm').addEventListener('submit', function (e) {
                if (!newPass || !conf) return;
                if (newPass.value !== conf.value) {
                    e.preventDefault();
                    conf.setCustomValidity('Passwords do not match.');
                    conf.reportValidity();
                    return;
                } else conf.setCustomValidity('');
                if (score(newPass.value) < 3) {
                    e.preventDefault();
                    alert('Please choose a stronger password.');
                    return;
                }
            });

            // init
            update();
        })();
    </script>
</body>
</html>