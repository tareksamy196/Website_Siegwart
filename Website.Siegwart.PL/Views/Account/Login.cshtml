@model Website.Siegwart.BLL.Dtos.Admin.AccountDtos.LoginAdminDto

@{
    ViewData["Title"] = "Admin Login";
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Siegwart</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/AdminLogin.css" asp-append-version="true" />
</head>
<body class="login-bg">
    <main class="d-flex align-items-center justify-content-center min-vh-100">
        <section class="login-card shadow-sm rounded">
            <header class="text-center mb-3">
                <img src="~/Resources/images/logo.png" alt="Siegwart" class="login-logo mb-2" />
                <h1 class="h5 mb-1">Admin sign in</h1>
                <p class="text-muted small mb-0">Enter your credentials to access the admin panel</p>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success" role="alert">@TempData["Success"]</div>
            }
            else if (TempData["Error"] != null)
            {
                <div class="alert alert-danger" role="alert">@TempData["Error"]</div>
            }

            <form asp-action="Login" method="post" id="loginForm" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label visually-hidden">Email</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="admin@example.com" autocomplete="email" required />
                    </div>
                    <small class="text-danger">@Html.ValidationMessageFor(m => m.Email)</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label visually-hidden">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="Password" autocomplete="current-password" required />
                        <button type="button" class="btn btn-outline-secondary btn-show-pass" aria-label="Toggle password visibility">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <small class="text-danger">@Html.ValidationMessageFor(m => m.Password)</small>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
                        <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                    </div>
                    <a href="#" id="forgotPasswordLink" class="small">Forgot password?</a>
                </div>

                <div class="d-grid">
                    <button id="submitBtn" type="submit" class="btn btn-primary btn-lg">
                        <span class="spinner-border spinner-border-sm me-2 d-none" id="submitSpinner" role="status" aria-hidden="true"></span>
                        <i class="bi bi-box-arrow-in-right me-1"></i>
                        Sign in
                    </button>
                </div>
            </form>

            <footer class="text-center mt-3">
                <a href="/" class="text-decoration-none">Back to website</a>
            </footer>
        </section>
    </main>

    <!-- Forgot Password Modal -->
    <div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-labelledby="forgotPasswordModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="forgotPasswordForm" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title" id="forgotPasswordModalLabel">Forgot password</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div id="fp-alert" class="d-none alert" role="alert"></div>

                        <div class="mb-3">
                            <label for="fp-email" class="form-label">Email</label>
                            <input id="fp-email" name="Email" type="email" class="form-control" placeholder="your-email@example.com" required />
                            <div class="invalid-feedback" id="fp-email-error"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button id="fp-submit" type="submit" class="btn btn-primary">Send reset link</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            // Login form behaviour
            const loginForm = document.getElementById('loginForm');
            const submitBtn = document.getElementById('submitBtn');
            const submitSpinner = document.getElementById('submitSpinner');
            if (loginForm) {
                loginForm.addEventListener('submit', function (e) {
                    if (!loginForm.checkValidity()) return;
                    submitBtn.disabled = true;
                    submitSpinner.classList.remove('d-none');
                });
            }

            // Toggle password visibility
            const showPassBtn = document.querySelector('.btn-show-pass');
            if (showPassBtn && loginForm) {
                showPassBtn.addEventListener('click', function () {
                    const pwd = loginForm.querySelector('input[name="Password"]');
                    if (!pwd) return;
                    const icon = this.querySelector('i');
                    if (pwd.type === 'password') {
                        pwd.type = 'text';
                        icon.classList.replace('bi-eye', 'bi-eye-slash');
                    } else {
                        pwd.type = 'password';
                        icon.classList.replace('bi-eye-slash', 'bi-eye');
                    }
                });
            }

            // Forgot password modal logic
            const forgotLink = document.getElementById('forgotPasswordLink');
            const forgotModalEl = document.getElementById('forgotPasswordModal');
            const forgotForm = document.getElementById('forgotPasswordForm');
            const fpEmail = document.getElementById('fp-email');
            const fpEmailError = document.getElementById('fp-email-error');
            const fpAlert = document.getElementById('fp-alert');
            const fpSubmit = document.getElementById('fp-submit');
            const bsModal = new bootstrap.Modal(forgotModalEl, { backdrop: 'static', keyboard: true });

            forgotLink.addEventListener('click', function (e) {
                e.preventDefault();
                fpEmail.value = '';
                fpEmail.classList.remove('is-invalid');
                fpEmailError.textContent = '';
                fpAlert.classList.add('d-none');
                fpAlert.classList.remove('alert-success', 'alert-danger');
                bsModal.show();
            });

            function getAntiForgeryToken() {
                const tokenInput = forgotForm.querySelector('input[name="__RequestVerificationToken"]');
                return tokenInput ? tokenInput.value : '';
            }

            forgotForm.addEventListener('submit', async function (e) {
                e.preventDefault();

                if (!fpEmail.checkValidity()) {
                    fpEmail.classList.add('is-invalid');
                    fpEmailError.textContent = 'Please enter a valid email address.';
                    return;
                } else {
                    fpEmail.classList.remove('is-invalid');
                    fpEmailError.textContent = '';
                }

                fpSubmit.disabled = true;
                fpSubmit.textContent = 'Sending...';

                try {
                    const token = getAntiForgeryToken();
                    if (!token) {
                        fpAlert.classList.remove('d-none');
                        fpAlert.classList.add('alert-danger');
                        fpAlert.textContent = 'Security token not found. Refresh the page and try again.';
                        fpSubmit.disabled = false;
                        fpSubmit.textContent = 'Send reset link';
                        return;
                    }

                    const params = new URLSearchParams();
                    params.append('__RequestVerificationToken', token);
                    params.append('Email', fpEmail.value.trim());

                    const res = await fetch('@Url.Action("ForgetPasswordModal", "Account")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: params.toString(),
                        credentials: 'same-origin'
                    });

                    const text = await res.text();

                    if (res.ok) {
                        let msg = 'If an account exists, a reset link has been sent.';
                        try { const json = JSON.parse(text); if (json && json.message) msg = json.message; } catch {}
                        fpAlert.classList.remove('d-none');
                        fpAlert.classList.remove('alert-danger');
                        fpAlert.classList.add('alert-success');
                        fpAlert.innerHTML = msg;
                        setTimeout(() => bsModal.hide(), 2500);
                    } else if (res.status === 400) {
                        try {
                            const err = JSON.parse(text);
                            if (err && err.errors && err.errors.Email) {
                                fpEmail.classList.add('is-invalid');
                                fpEmailError.textContent = err.errors.Email.join(' ');
                            } else if (err && err.message) {
                                fpAlert.classList.remove('d-none');
                                fpAlert.classList.add('alert-danger');
                                fpAlert.textContent = err.message;
                            } else {
                                fpAlert.classList.remove('d-none');
                                fpAlert.classList.add('alert-danger');
                                fpAlert.textContent = 'Validation failed.';
                            }
                        } catch {
                            fpAlert.classList.remove('d-none');
                            fpAlert.classList.add('alert-danger');
                            fpAlert.textContent = text || 'Validation failed.';
                        }
                    } else {
                        fpAlert.classList.remove('d-none');
                        fpAlert.classList.add('alert-danger');
                        fpAlert.textContent = 'Unexpected error. Try again later.';
                        console.error('ForgetPasswordModal failed:', res.status, text);
                    }
                } catch (ex) {
                    fpAlert.classList.remove('d-none');
                    fpAlert.classList.add('alert-danger');
                    fpAlert.textContent = 'Network error. Try again later.';
                    console.error('Network error sending forget password:', ex);
                } finally {
                    fpSubmit.disabled = false;
                    fpSubmit.textContent = 'Send reset link';
                }
            });
        })();
    </script>
</body>
</html>