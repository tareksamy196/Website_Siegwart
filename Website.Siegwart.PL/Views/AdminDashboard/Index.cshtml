@using Website.Siegwart.PL.Controllers
@model DashboardStatsViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link type="text/css" rel="stylesheet" href="~/css/AdminDashboard.css" />
<link type="text/css" rel="stylesheet" href="~/css/Admin.Bundle.Min.css" />


<!-- Dashboard Header -->
<div class="dashboard-header">
    <div class="dashboard-title">
        <i class="bi bi-speedometer2 me-2"></i>
        Dashboard
    </div>
    <div class="dashboard-subtitle">
        Welcome back, @User.Identity?.Name
    </div>
</div>

<!-- Statistics Cards -->
<div class="row g-3 mb-4">
    <!-- Categories -->
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon primary">
                <i class="bi bi-tags-fill"></i>
            </div>
            <div class="stat-number">@Model.TotalCategories</div>
            <div class="stat-label">Total Categories</div>
            <div class="mt-3">
                <a asp-controller="AdminCategories" asp-action="Index" class="text-decoration-none small fw-semibold" style="color: #0096FF;">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Products -->
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon success">
                <i class="bi bi-box-seam-fill"></i>
            </div>
            <div class="stat-number">@Model.TotalProducts</div>
            <div class="stat-label">Total Products</div>
            <div class="stat-details">
                <span class="stat-badge active">@Model.ActiveProducts Active</span>
                <span class="stat-badge inactive">@Model.InactiveProducts Inactive</span>
            </div>
        </div>
    </div>

    <!-- News -->
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon info">
                <i class="bi bi-newspaper"></i>
            </div>
            <div class="stat-number">@Model.TotalNews</div>
            <div class="stat-label">Total News</div>
            <div class="stat-details">
                <span class="stat-badge active">@Model.PublishedNews Published</span>
                <span class="stat-badge draft">@Model.DraftNews Draft</span>
            </div>
        </div>
    </div>

    <!-- Team Members -->
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon warning">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="stat-number">@Model.TotalTeamMembers</div>
            <div class="stat-label">Team Members</div>
            <div class="stat-details">
                <span class="stat-badge active">@Model.ActiveTeamMembers Active</span>
                <span class="stat-badge inactive">@Model.InactiveTeamMembers Inactive</span>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions-card">
    <div class="quick-actions-title">
        <i class="bi bi-lightning-charge-fill"></i>
        Quick Actions
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="AdminProducts" asp-action="Create" class="quick-action-btn btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            New Product
        </a>
        <a asp-controller="AdminNews" asp-action="Create" class="quick-action-btn btn btn-success">
            <i class="bi bi-plus-circle"></i>
            New News
        </a>
        <a asp-controller="AdminTeamMember" asp-action="Create" class="quick-action-btn btn btn-info text-white">
            <i class="bi bi-plus-circle"></i>
            New Team Member
        </a>
        <a asp-controller="AdminCategories" asp-action="Create" class="quick-action-btn btn btn-warning text-white">
            <i class="bi bi-plus-circle"></i>
            New Category
        </a>
    </div>
</div>

<!-- Recent Items -->
<div class="row g-3">
    <!-- Recent Products -->
    <div class="col-md-6">
        <div class="recent-items-card">
            <div class="recent-items-title">
                <i class="bi bi-clock-history"></i>
                Recent Products
            </div>

            @if (Model.RecentProducts.Any())
            {
                @foreach (var product in Model.RecentProducts)
                {
                    <div class="recent-item">
                        <div class="recent-item-title">@product.Title</div>
                        <div class="recent-item-meta">
                            <span>
                                <i class="bi bi-calendar3 me-1"></i>
                                @product.CreatedOn.ToString("MMM dd, yyyy")
                            </span>
                            @if (product.IsActive)
                            {
                                <span class="stat-badge active">Active</span>
                            }
                            else
                            {
                                <span class="stat-badge inactive">Inactive</span>
                            }
                        </div>
                    </div>
                }
                <div class="mt-3">
                    <a asp-controller="AdminProducts" asp-action="Index" class="text-decoration-none small fw-semibold" style="color: #0096FF;">
                        View All Products <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <div>No products yet</div>
                </div>
            }
        </div>
    </div>

    <!-- Recent News -->
    <div class="col-md-6">
        <div class="recent-items-card">
            <div class="recent-items-title">
                <i class="bi bi-clock-history"></i>
                Recent News
            </div>

            @if (Model.RecentNews.Any())
            {
                @foreach (var news in Model.RecentNews)
                {
                    <div class="recent-item">
                        <div class="recent-item-title">@news.Title</div>
                        <div class="recent-item-meta">
                            <span>
                                <i class="bi bi-calendar3 me-1"></i>
                                @news.CreatedOn.ToString("MMM dd, yyyy")
                            </span>
                            @if (news.IsActive)
                            {
                                <span class="stat-badge active">Published</span>
                            }
                            else
                            {
                                <span class="stat-badge draft">Draft</span>
                            }
                        </div>
                    </div>
                }
                <div class="mt-3">
                    <a asp-controller="AdminNews" asp-action="Index" class="text-decoration-none small fw-semibold" style="color: #0096FF;">
                        View All News <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <div>No news yet</div>
                </div>
            }
        </div>
    </div>
</div>